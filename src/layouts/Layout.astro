---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { getLangFromUrl } from '@/i18n/utils';
import { ViewTransitions } from 'astro:transitions';

const lang = getLangFromUrl(Astro.url);

const { title, description = '', author = '' } = Astro.props;
---
<html lang={lang}>

<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Kanit:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
	<link rel="stylesheet" href="/styles/reset.css">
	<link rel="stylesheet" href="/styles/global.css">
    <script src="../scripts/menu.js"></script>
    <script src="../scripts/animate.js"></script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no" />
    <title>{ title }</title>
    {description && <meta name="description" content={description} />}
    {author && <meta name="author" content={author} />}
    <ViewTransitions />
</head>
<body
	class='cursor-default relative container xl:max-w-7xl font-sans md:px-5 mx-auto tracking-wide text-zinc-200 bg-[#040404]'>
	<Header />
	<div class='md:flex md:flex-col md:min-h-full'>
		<slot />
	</div>
	<Footer />
</body>
</html>
